{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wikimemory-passkey-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/web",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "vars": {
    "APP_ENV": "local",
    "APP_BASE_URL": "http://localhost:8792",
    "SETUP_TOKEN_HASH": "eef8025387059984240b9e91b663ef3fe1e0661bbb1bedfe55eb8d4b17e7ceff"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wikimemory-passkey-test",
      "database_id": "11111111-1111-4111-8111-111111111111",
      "migrations_dir": "migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "22222222222222222222222222222222"
    }
  ]
}
